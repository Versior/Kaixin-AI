# 管理员账号，首次启动会自动创建。
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# JWT 登录密钥和过期时间，正式部署请务必修改 JWT_SECRET。
# 生成方式：openssl rand -hex 32
JWT_SECRET=changeme
JWT_EXPIRE_HOURS=168

# 后端监听端口
PORT=8080

# 前端开发代理默认使用 http://127.0.0.1:8080，如后端开发端口不同，启动前端时可单独设置 API_BASE_URL。
# API_BASE_URL=http://127.0.0.1:8080

# 数据库配置，默认使用本地 SQLite。
STORAGE_DRIVER=sqlite
# sqlite
DATABASE_DSN=data/infinite-canvas.db
# mysql
# DATABASE_DSN=user:password@tcp(127.0.0.1:3306)/infinite_canvas?parseTime=true
# postgres
# DATABASE_DSN=postgres://user:password@127.0.0.1:5432/infinite_canvas?sslmode=disable

# 图片公网访问地址（替换为你的公网域名或 IP:端口）
PUBLIC_IMAGE_BASE_URL=http://localhost:3000

# 前端容器映射端口（宿主机端口）
FRONTEND_PORT=3000

# SMTP 配置（可选，用于邮箱验证码注册）
# SMTP_HOST=smtp.example.com
# SMTP_PORT=465
# SMTP_USERNAME=your-email@example.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=your-email@example.com
# SMTP_USE_TLS=true

# 内部图片地址重写（可选，JSON 对象格式）
# INTERNAL_IMAGE_HOST_REWRITES={"localhost":"host.docker.internal","127.0.0.1":"host.docker.internal"}

# 后端内部图片前缀重写（可选，JSON 数组格式）
# INTERNAL_IMAGE_HOST_PREFIXES=["http://127.0.0.1:3000","http://localhost:3000"]
